{
  "name": "troels-lund-personal-website",
  "version": "1.0.0",
  "description": "personal website of Troels Lund",
  "homepage": "https://troelslund.dk",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "scan": "next dev & npx react-scan@latest localhost:3000",
    "build": "next build",
    "csp:inject": "node scripts/inject-csp.js out",
    "start": "npx serve@latest out",
    "find:unused": "knip",
    "prepare": "husky",
    "test": "jest --runInBand",
    "format": "prettier --write \"**/*.{js,ts,tsx}\"",
    "lint": "npx eslint --cache . --ext .ts,.tsx",
    "lint:fix": "npx eslint --cache . --ext .ts,.tsx --fix",
    "format:lint": "npm run lint:fix && npm run format",
    "optimize-images": "node scripts/optimize-images.js",
    "remove:optimize-images": "node scripts/remove-optimized-images.js",
    "remove:unused": "knip --fix"
  },
  "prepare": "husky || true",
  "lint-staged": {
    "*.ts,*.jsx": "eslint --cache --fix"
  },
  "dependencies": {
    "@cronitorio/cronitor-rum": "^0.4.1",
    "@oddbird/popover-polyfill": "^0.7.0",
    "date-fns": "4.1.0",
    "framer-motion": "^12.23.24",
    "gray-matter": "4.0.3",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "react-toastify": "^11.0.5",
    "rehype-katex": "^7.0.1",
    "rehype-meta": "^4.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "latest",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "babel-plugin-react-compiler": "latest",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^16.0.0",
    "knip": "^5.0.0",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react-scan": "^0.4.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "npm": ">=6.0.0",
    "node": ">=20.9.0"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ]
}
